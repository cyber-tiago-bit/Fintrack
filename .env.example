# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA suba o .env para o GitHub!

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_ID].supabase.co:5432/postgres

# Segredo JWT (gere um aleatório: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=sua_chave_secreta_aqui_minimo_32_caracteres

# Configurações do token
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
